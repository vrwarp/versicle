{
  // Composite project for the package's tests: the fork's ported unit suite
  // (test/unit/**, vendored — compiled with the library's non-strict surface)
  // and the first-party contract suite (test/contract/**). Referenced from
  // the root tsconfig.json so test code typechecking stays a build invariant
  // (Phase 0 rule). Imports into the library source are redirected to
  // ./dist-types declarations via the project reference below.
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["vitest/globals"],
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": ".",
    "outDir": "./dist-types-test",
    "tsBuildInfoFile": "./dist-types-test/tsconfig.tsbuildinfo"
  },
  "include": ["test/**/*.ts"],
  "references": [{ "path": "./tsconfig.json" }]
}
