{
  // Composite project for the package's tests: the ported upstream specs
  // (src/**/*.spec.ts) and the Phase 2 contract suite (test/**). Referenced
  // from the root tsconfig.json so test code typechecking stays a build
  // invariant (Phase 0 rule). Imports into the library source are redirected
  // to ./dist-types declarations via the project reference below.
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["vitest/globals"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": ".",
    "outDir": "./dist-types-test",
    "tsBuildInfoFile": "./dist-types-test/tsconfig.tsbuildinfo"
  },
  "include": ["src/**/*.spec.ts", "test/**/*.ts"],
  "references": [{ "path": "./tsconfig.json" }]
}
