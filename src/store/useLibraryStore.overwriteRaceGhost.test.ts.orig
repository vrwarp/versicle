import { describe, it, expect, beforeEach, vi } from 'vitest';
import { createLibraryStore, useBookStore } from './useLibraryStore';

describe('LibraryStore ghost overwrite race conditions', () => {
  beforeEach(() => {
    useBookStore.setState({ books: {} });
  });

  it('should not overwrite concurrent updates during ghost book match', async () => {
    let resolveImport: any;
    const importPromise = new Promise((resolve) => { resolveImport = resolve; });

    const mockDb = {
      getBookIdByFilename: vi.fn(async () => undefined), // force ghost match
      importBookWithId: vi.fn(() => importPromise),
    };

    // Need to mock extractBookMetadata
    vi.mock('../lib/ingestion', () => ({
      extractBookMetadata: vi.fn(async () => ({ title: 'Old', author: 'Old' })),
    }));

    const useLibraryStore = createLibraryStore(mockDb as any);

    // Initial state
    useBookStore.setState({
      books: {
        'existing-id': {
          bookId: 'existing-id',
          title: 'Old',
          author: 'Old',
          addedAt: 500,
          lastInteraction: 500,
          status: 'unread',
          tags: []
        } as any
      }
    });

    useLibraryStore.setState({
      staticMetadata: {} // no local metadata, so it counts as ghost
    });

    const file = new File([''], 'test.epub', { type: 'application/epub+zip' });

    // Start overwrite
    const addPromise = useLibraryStore.getState().addBook(file);

    // Concurrently update the book in the sync store
    useBookStore.getState().updateBook('existing-id', { tags: ['concurrent-tag'] });

    // Resolve the import
    resolveImport({ bookId: 'existing-id', title: 'New', author: 'A', schemaVersion: 1 });

    await addPromise;

    // The concurrent update should not be lost
    const book = useBookStore.getState().books['existing-id'];
    expect(book.tags).toContain('concurrent-tag');
  });
});
