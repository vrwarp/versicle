  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "depcruise": "depcruise src --config .dependency-cruiser.cjs",
    "depcruise:baseline": "node scripts/depcruise-baseline.mjs",
    "depcruise:check": "node scripts/depcruise-baseline.mjs --check",
    "check:worker-chunk": "node scripts/check-worker-chunk.mjs",
    "check:single-instance": "node scripts/assert-single-instance.cjs",
    "knip": "knip",
    "lintdebt:check": "node scripts/lint-debt-ratchet.mjs --check",
    "lintdebt:update": "node scripts/lint-debt-ratchet.mjs --update",
    "licenses:generate": "node scripts/generate-third-party-notices.mjs",
    "licenses:check": "node scripts/license-gate.mjs",
    "generate:csp": "node scripts/generate-csp.mjs",
    "docs:generate": "REGEN_DOCS=1 REGEN_STORE_DOCS=1 vitest run src/app/docs/docs.test.ts src/store/__tests__/registry.test.ts",
    "generate:csp:check": "node scripts/generate-csp.mjs --check",
    "compile-dict": "node scripts/compile-dict.cjs",
    "generate-trad2simp": "node scripts/generate-trad2simp.mjs",
    "test": "vitest run",
    "tests": "vitest run",
    "coverage": "vitest run --coverage",
    "preview": "vite preview",
    "postinstall": "patch-package"
